[HKEY_CLASSES_ROOT\MIME\Database\Content Type\text/xml]
"CLSID"="{6CFA19FA-E091-4d4f-BF7F-ADD3DC060A4F}"
"Extension"=".xml"

[HKEY_CLASSES_ROOT\MIME\Database\Content Type\text/xsl]
"CLSID"="{6CFA19FA-E091-4d4f-BF7F-ADD3DC060A4F}"
