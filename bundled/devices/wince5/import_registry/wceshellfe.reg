"CLSID"="{6CFA19FA-E091-4d4f-BF7F-ADD3DC060A4F}"
"Extension"=".png"

[HKEY_CLASSES_ROOT\.htm]
@="htmlfile"
[HKEY_CLASSES_ROOT\.html]
@="htmlfile"
[HKEY_CLASSES_ROOT\htmlfile]
@=mui_sz:"urlmon.dll,#9001"

[HKEY_CLASSES_ROOT\.gif]
@="gifimage"
[HKEY_CLASSES_ROOT\gifimage]
@=mui_sz:"urlmon.dll,#9006"

[HKEY_CLASSES_ROOT\.jpg]
@="jpegimage"
[HKEY_CLASSES_ROOT\.jpeg]
@="jpegimage"
[HKEY_CLASSES_ROOT\jpegimage]
@=mui_sz:"urlmon.dll,#9007"

[HKEY_CLASSES_ROOT\.url]
@="urlfile"
[HKEY_CLASSES_ROOT\urlfile]
@=mui_sz:"urlmon.dll,#9010"

; Bitmap registry values
[HKEY_CLASSES_ROOT\.2bp]
@="bmpimage"
[HKEY_CLASSES_ROOT\.bmp]
@="bmpimage"
[HKEY_CLASSES_ROOT\bmpimage]
@=mui_sz:"urlmon.dll,#9009"

[HKEY_CLASSES_ROOT\.png]
@="pngimage"
"Content Type"="image/x-png"

[HKEY_CLASSES_ROOT\.xml]
@="xmlfile"
"Content Type"="text/xml"

[HKEY_CLASSES_ROOT\.xsl]
@="xslfile"
"Content Type"="text/xml"

; URL Protocols
[HKEY_CLASSES_ROOT\http]
@="URL:HyperText Transfer Protocol"
"URL Protocol"=""

[HKEY_CLASSES_ROOT\https]
@="URL:HyperText Transfer Protocol"
"URL Protocol"=""

[HKEY_CLASSES_ROOT\ftp]
@="URL:File Transfer Protocol"
"URL Protocol"=""

[HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Internet Explorer\MediaTypeClass\{6CFA19FA-E091-4d4f-BF7F-ADD3DC060A4F}]
"text/html"=""
[HKEY_CLASSES_ROOT\CLSID\{6CFA19FA-E091-4d4f-BF7F-ADD3DC060A4F}\InprocServer32]
@="browser.dll"
[HKEY_CLASSES_ROOT\CLSID\{657FE5A4-C9DB-4AF1-B9C1-E4422F66AE22}]
@="Download Request Manager"
